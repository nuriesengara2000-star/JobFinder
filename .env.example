# Telegram bot token is needed only if you run the Telegram bot
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Database URL
# Local SQLite example:
# DATABASE_URL=sqlite+aiosqlite:///./jobs.db
# Railway PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
DATABASE_URL=sqlite+aiosqlite:///./jobs.db

# Optional app settings
SCORING_CONCURRENCY=3
PAGE_SIZE=3

# Railway provides PORT automatically. Locally, the backend uses 8000 by default.
PORT=8000
