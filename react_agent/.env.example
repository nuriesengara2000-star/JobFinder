# Copy this file to `.env` and fill in real values.

# --- OpenAI ---------------------------------------------------------------
# Required: your OpenAI API key (https://platform.openai.com/api-keys).
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: which OpenAI model to use for resume parsing and the ReAct loop.
# Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# --- HeadHunter -----------------------------------------------------------
# Required by HH for ALL requests. Format MUST be: `AppName/version (your-email)`.
# The email must be a real domain (gmail.com is fine; example.com is blacklisted).
HH_USER_AGENT=JobFinder/1.0 (your-email@gmail.com)

# Optional but RECOMMENDED. HH now blocks anonymous /vacancies access from
# many IPs (you'll see HTTP 403 "forbidden"). To fix:
#   1. Register an application at https://dev.hh.ru/admin (free)
#   2. Get an OAuth Bearer token (client_credentials grant)
#   3. Paste it here. The agent will send it as `Authorization: Bearer <token>`.
HH_TOKEN=

# --- Misc -----------------------------------------------------------------
# Optional: log level (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
LOG_LEVEL=INFO
